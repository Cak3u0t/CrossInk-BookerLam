<file path="src/activities/home/BookActions.cpp">
#include "BookActions.h"

#include <Epub.h>
#include <FsHelpers.h>
#include <GfxRenderer.h>
#include <HalStorage.h>
#include <I18n.h>
#include <Logging.h>
#include <Xtc.h>

#include <cstdio>

#include "BookmarkStore.h"
#include "CrossPointSettings.h"
#include "CrossPointState.h"
