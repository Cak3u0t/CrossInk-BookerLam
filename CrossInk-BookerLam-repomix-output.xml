  </div>
</div>

<!-- Failed Uploads Banner -->
<div class="failed-uploads-banner" id="failedUploadsBanner">
  <div class="failed-uploads-header">
    <h3 class="failed-uploads-title">⚠️ Some files failed to upload</h3>
